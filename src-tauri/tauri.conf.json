{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "雨音输入法",
  "version": "1.0.0",
  "identifier": "io.github.rain.voice-input",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "security": {
      "csp": "default-src 'self'; style-src 'self'; script-src 'self'"
    },
    "windows": [
      {
        "label": "main",
        "title": "雨音输入法",
        "url": "index.html",
        "width": 980,
        "height": 700,
        "minWidth": 820,
        "minHeight": 620,
        "center": true,
        "decorations": false,
        "transparent": false
      },
      {
        "label": "overlay",
        "url": "overlay.html",
        "width": 440,
        "height": 72,
        "visible": false,
        "focus": false,
        "focusable": false,
        "alwaysOnTop": true,
        "decorations": false,
        "transparent": true,
        "resizable": false,
        "skipTaskbar": true,
        "shadow": false
      },
      {
        "label": "overlay-cancel",
        "url": "cancel.html",
        "width": 77,
        "height": 38,
        "visible": false,
        "focus": false,
        "focusable": false,
        "alwaysOnTop": true,
        "decorations": false,
        "transparent": true,
        "resizable": false,
        "skipTaskbar": true,
        "shadow": false
      }
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "",
      "endpoints": [],
      "windows": {
        "installMode": "passive"
      }
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["nsis"],
    "shortDescription": "Rain Vibetype 本地优先的 Windows 11 语音输入法",
    "longDescription": "雨音输入法通过全局快捷键录音，使用本地语音模型识别并安全输入文字。"
  }
}
